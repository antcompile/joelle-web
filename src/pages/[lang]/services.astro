---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../islands/ScrollReveal.tsx';
import { type Lang, languages } from '../../i18n/languages';
import { useTranslation, getLocalizedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
---

<BaseLayout title={t('nav.services')} lang={lang}>
  <div class="pt-32 pb-24 lg:pb-32">
    <!-- Header -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 mb-24">
      <h1 class="font-serif text-[clamp(2.5rem,5vw,3.5rem)] tracking-[0.05em] mb-6">
        {t('services.title')}
      </h1>
    </section>

    <!-- Service A: Architecture d'interieur -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 mb-32">
      <ScrollReveal client:visible>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src="/joelle-web/images/services/architecture-sketch.jpg"
              alt={t('services.architecture')}
              class="w-full h-full object-cover"
            />
          </div>
          <div>
            <h2 class="font-serif text-2xl lg:text-3xl tracking-wide mb-8">
              {t('services.architecture')}
            </h2>
            <p class="text-[var(--text-secondary)] leading-relaxed mb-8">
              {t('services.architectureDesc')}
            </p>

            <!-- Sub-services cards -->
            <div class="space-y-10">
              <!-- Residentiel -->
              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">{t('services.residential')}</h3>
                <p class="text-sm text-[var(--text-secondary)] mb-4">{t('services.residentialDesc')}</p>
                <ul class="grid grid-cols-2 gap-2 text-sm text-[var(--text-muted)]">
                  <li>Plans et elevations</li>
                  <li>Selection des materiaux</li>
                  <li>Eclairage</li>
                  <li>Mobilier sur mesure</li>
                </ul>
              </div>

              <!-- Commercial -->
              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">{t('services.commercial')}</h3>
                <p class="text-sm text-[var(--text-secondary)] mb-4">{t('services.commercialDesc')}</p>
                <ul class="grid grid-cols-2 gap-2 text-sm text-[var(--text-muted)]">
                  <li>Amenagement spatial</li>
                  <li>Identite de marque</li>
                  <li>Conformite reglementaire</li>
                  <li>Gestion de projet</li>
                </ul>
              </div>

              <!-- Consultation -->
              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">{t('services.consultation')}</h3>
                <p class="text-sm text-[var(--text-secondary)] mb-4">{t('services.consultationDesc')}</p>
                <ul class="grid grid-cols-2 gap-2 text-sm text-[var(--text-muted)]">
                  <li>Palette de couleurs</li>
                  <li>Moodboards</li>
                  <li>Specifications materiaux</li>
                  <li>Direction artistique</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </ScrollReveal>
    </section>

    <!-- Service B: Mobilier multifonctionnel -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 mb-32">
      <ScrollReveal client:visible>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="order-2 lg:order-1">
            <h2 class="font-serif text-2xl lg:text-3xl tracking-wide mb-8">
              {t('services.furniture')}
            </h2>
            <p class="text-[var(--text-secondary)] leading-relaxed mb-8">
              {lang === 'fr'
                ? "Une approche design centree sur l'optimisation de l'espace, la modularite, la multifonction et l'esthetique minimaliste."
                : "A design approach centered on space optimization, modularity, multifunction, and minimalist aesthetics."}
            </p>

            <div class="space-y-10">
              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">
                  {lang === 'fr' ? 'Design de mobilier' : 'Furniture Design'}
                </h3>
                <p class="text-sm text-[var(--text-secondary)]">
                  {lang === 'fr'
                    ? "Conception de pieces uniques et intelligentes adaptees aux petits espaces."
                    : "Unique and intelligent pieces designed for small spaces."}
                </p>
              </div>

              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">
                  {lang === 'fr' ? 'Mobilier multifonctionnel' : 'Multifunctional Furniture'}
                </h3>
                <p class="text-sm text-[var(--text-secondary)]">
                  {lang === 'fr'
                    ? "Meubles hybrides combinant plusieurs usages (travail, rangement, repos, etc.)."
                    : "Hybrid furniture combining multiple uses (work, storage, rest, etc.)."}
                </p>
              </div>

              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">
                  {lang === 'fr' ? 'Sur mesure' : 'Custom Made'}
                </h3>
                <p class="text-sm text-[var(--text-secondary)]">
                  {lang === 'fr'
                    ? "Adaptation complete aux besoins du client, aux contraintes d'espace et au mode de vie."
                    : "Complete adaptation to client needs, space constraints, and lifestyle."}
                </p>
              </div>

              <div class="border-t border-[var(--border)] pt-6">
                <h3 class="font-sans font-medium text-lg mb-3">
                  {lang === 'fr' ? 'Choix des materiaux & finitions' : 'Materials & Finishes'}
                </h3>
                <p class="text-sm text-[var(--text-secondary)]">
                  {lang === 'fr'
                    ? "Approche durable avec materiaux responsables et finitions haut de gamme."
                    : "Sustainable approach with responsible materials and premium finishes."}
                </p>
              </div>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <!-- Video Preview (autoplay, muted, loop) -->
            <div class="aspect-[4/3] overflow-hidden relative cursor-pointer group" id="video-preview-container">
              <video
                id="video-preview"
                class="w-full h-full object-cover"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              >
                <source src="/joelle-web/videos/furniture-preview.mp4" type="video/mp4" />
              </video>
              <!-- Play button overlay -->
              <div class="absolute inset-0 flex items-center justify-center bg-black/10 group-hover:bg-black/20 transition-colors duration-300">
                <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-6 h-6 text-[var(--text-primary)] ms-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Video Modal (fullscreen with controls) -->
          <div id="video-modal" class="fixed inset-0 z-[200] bg-black/95 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
            <button id="video-modal-close" class="absolute top-6 right-6 text-white/80 hover:text-white cursor-pointer z-10 p-2">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <video
              id="video-fullscreen"
              class="w-full max-w-5xl max-h-[85vh] object-contain"
              controls
              preload="none"
            >
              <source src="/joelle-web/videos/furniture-preview.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </ScrollReveal>
    </section>

    <!-- CTA -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 text-center">
      <ScrollReveal client:visible>
        <h2 class="font-serif text-2xl tracking-wide mb-6">
          {lang === 'fr' ? 'Discutons de votre projet' : "Let's discuss your project"}
        </h2>
        <a href={getLocalizedPath(lang, '/contact')} class="btn-primary">
          {t('common.getInTouch')}
        </a>
      </ScrollReveal>
    </section>
  </div>
</BaseLayout>

<script>
  const previewContainer = document.getElementById('video-preview-container');
  const modal = document.getElementById('video-modal');
  const modalClose = document.getElementById('video-modal-close');
  const fullscreenVideo = document.getElementById('video-fullscreen') as HTMLVideoElement | null;
  const previewVideo = document.getElementById('video-preview') as HTMLVideoElement | null;

  previewContainer?.addEventListener('click', () => {
    if (!modal || !fullscreenVideo) return;
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    fullscreenVideo.currentTime = previewVideo?.currentTime || 0;
    fullscreenVideo.muted = false;
    fullscreenVideo.play();
    document.body.style.overflow = 'hidden';
  });

  function closeModal() {
    if (!modal || !fullscreenVideo) return;
    modal.classList.add('opacity-0', 'pointer-events-none');
    modal.classList.remove('opacity-100', 'pointer-events-auto');
    fullscreenVideo.pause();
    document.body.style.overflow = '';
  }

  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
