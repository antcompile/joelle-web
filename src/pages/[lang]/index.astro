---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroAnimation from '../../islands/HeroAnimation.tsx';
import ScrollReveal from '../../islands/ScrollReveal.tsx';
import { type Lang, languages } from '../../i18n/languages';
import { useTranslation, getLocalizedContent, getLocalizedPath } from '../../i18n/utils';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title={t('nav.home')} description={t('hero.subtitle')} lang={lang}>
  <!-- HERO -->
  <section data-hero class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/50 z-10"></div>
    <img
      src="/joelle-web/images/hero/hero-main.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 px-6 max-w-5xl mx-auto text-center">
      <p class="font-serif text-sm tracking-[0.6em] uppercase text-white/80 mb-8">
        PLUS EN MOINS
      </p>
      <HeroAnimation client:load title={t('hero.title')} subtitle={t('hero.subtitle')} />
      <div class="mt-12 flex justify-center">
        <a href={getLocalizedPath(lang, '/services')} class="btn-primary">
          {t('hero.cta')}
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 lg:py-32 px-6 lg:px-8 max-w-[1440px] mx-auto">
    <ScrollReveal client:visible>
      <div class="text-center mb-16">
        <h2 class="font-serif text-[clamp(1.75rem,3vw,2.5rem)] text-[var(--text-primary)] tracking-wide">
          {t('services.title')}
        </h2>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      <!-- Architecture d'interieur -->
      <ScrollReveal client:visible delay={0}>
        <a href={getLocalizedPath(lang, '/services')} class="group block relative aspect-[4/5] overflow-hidden cursor-pointer">
          <img
            src="/joelle-web/images/services/architecture-sketch.jpg"
            alt={t('services.architecture')}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 lg:p-10">
            <h3 class="font-serif text-xl lg:text-2xl text-white tracking-wide mb-2">
              {t('services.architecture')}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed max-w-md">
              {t('services.architectureDesc')}
            </p>
          </div>
        </a>
      </ScrollReveal>

      <!-- Mobilier multifonctionnel -->
      <ScrollReveal client:visible delay={0.15}>
        <a href={getLocalizedPath(lang, '/services')} class="group block relative aspect-[4/5] overflow-hidden cursor-pointer">
          <img
            src="/joelle-web/images/services/furniture-sketch.jpg"
            alt={t('services.furniture')}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 lg:p-10">
            <h3 class="font-serif text-xl lg:text-2xl text-white tracking-wide mb-2">
              {t('services.furniture')}
            </h3>
            <p class="text-white/70 text-sm leading-relaxed max-w-md">
              {t('services.furnitureDesc')}
            </p>
          </div>
        </a>
      </ScrollReveal>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="py-24 lg:py-32 bg-[var(--surface-alt)]">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <ScrollReveal client:visible>
        <div>
          <p class="text-xs font-sans font-medium uppercase tracking-[0.2em] text-[var(--accent)] mb-6">
            {t('about.title')}
          </p>
          <blockquote class="font-serif text-2xl lg:text-3xl leading-relaxed text-[var(--text-primary)] mb-8">
            "{t('about.teaser')}"
          </blockquote>
          <p class="text-[var(--text-secondary)] mb-10 max-w-prose leading-relaxed">
            Joelle Trad - {getLocalizedContent(siteConfig.tagline, lang)}
          </p>
          <a href={getLocalizedPath(lang, '/about')} class="btn-secondary">
            {t('about.learnMore')}
          </a>
        </div>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2}>
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="/joelle-web/images/about/portrait.jpg"
            alt="Joelle Trad"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <ScrollReveal client:visible>
        <h2 class="font-serif text-[clamp(1.75rem,4vw,3rem)] text-[var(--text-primary)] mb-6 tracking-wide">
          {t('contact.heading')}
        </h2>
        <p class="text-[var(--text-secondary)] mb-10 max-w-lg mx-auto">
          {t('contact.availability')}
        </p>
        <a href={getLocalizedPath(lang, '/contact')} class="btn-primary">
          {t('common.getInTouch')}
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
