---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroAnimation from '../../islands/HeroAnimation.tsx';
import ScrollReveal from '../../islands/ScrollReveal.tsx';
import SectionHeading from '../../components/SectionHeading.astro';
import { type Lang, languages } from '../../i18n/languages';
import { useTranslation, getLocalizedContent, getLocalizedPath } from '../../i18n/utils';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);

// Load featured projects
const projectFiles = import.meta.glob('../../content/projects/*.json', { eager: true });
const projects = Object.values(projectFiles)
  .map((mod: any) => mod.default || mod)
  .filter((p: any) => p.featured)
  .sort((a: any, b: any) => a.order - b.order);
---

<BaseLayout title={t('nav.home')} description={t('hero.subtitle')} lang={lang}>
  <!-- HERO -->
  <section data-hero class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-warm-black/50 via-warm-black/30 to-warm-black/60 z-10"></div>
    <img
      src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=1920&q=80"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="relative z-20 px-6 max-w-4xl mx-auto">
      <HeroAnimation client:load title={t('hero.title')} subtitle={t('hero.subtitle')} />
      <div class="mt-10 flex justify-center">
        <a href={getLocalizedPath(lang, '/projects')} class="btn-primary">
          {t('hero.cta')}
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
    </div>
  </section>

  <!-- SELECTED PROJECTS -->
  <section class="py-24 lg:py-32 px-6 lg:px-8 max-w-[1440px] mx-auto">
    <ScrollReveal client:visible>
      <SectionHeading title={t('projects.title')} />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project: any, i: number) => (
        <ScrollReveal client:visible delay={i * 0.15}>
          <a
            href={getLocalizedPath(lang, `/projects/${project.slug}`)}
            class="group block overflow-hidden cursor-pointer"
          >
            <div class="relative aspect-[4/3] overflow-hidden bg-[var(--surface-alt)]">
              <img
                src={`https://images.unsplash.com/photo-${1600210492486 + i * 1000000000}?w=800&q=75`}
                alt={getLocalizedContent(project.title, lang)}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>
            <div class="mt-4">
              <h3 class="font-serif text-xl font-semibold">
                {getLocalizedContent(project.title, lang)}
              </h3>
              <p class="text-sm text-[var(--text-muted)] mt-1">
                {getLocalizedContent(project.location, lang)} — {project.year}
              </p>
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a href={getLocalizedPath(lang, '/projects')} class="btn-secondary">
        {t('projects.viewAll')}
      </a>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="py-24 lg:py-32 bg-[var(--surface-alt)] relative grain-overlay">
    <div class="max-w-[1440px] mx-auto px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <ScrollReveal client:visible>
        <div>
          <blockquote class="font-serif text-2xl lg:text-3xl leading-relaxed text-[var(--text-primary)] mb-6">
            "{t('about.teaser')}"
          </blockquote>
          <p class="text-[var(--text-secondary)] mb-8 max-w-prose">
            Joelle Trad — {getLocalizedContent(siteConfig.tagline, lang)}
          </p>
          <a href={getLocalizedPath(lang, '/about')} class="btn-secondary">
            {t('about.learnMore')}
          </a>
        </div>
      </ScrollReveal>
      <ScrollReveal client:visible delay={0.2}>
        <div class="aspect-[4/5] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=75"
            alt="Joelle Trad"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-24 lg:py-32 px-6 lg:px-8 max-w-[1440px] mx-auto">
    <ScrollReveal client:visible>
      <SectionHeading title={t('services.title')} />
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <ScrollReveal client:visible delay={0}>
        <div>
          <div class="w-12 h-12 mb-4 text-[var(--accent)]">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">{t('services.residential')}</h3>
          <p class="text-[var(--text-secondary)] text-sm leading-relaxed">{t('services.residentialDesc')}</p>
        </div>
      </ScrollReveal>

      <ScrollReveal client:visible delay={0.15}>
        <div>
          <div class="w-12 h-12 mb-4 text-[var(--accent)]">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">{t('services.commercial')}</h3>
          <p class="text-[var(--text-secondary)] text-sm leading-relaxed">{t('services.commercialDesc')}</p>
        </div>
      </ScrollReveal>

      <ScrollReveal client:visible delay={0.3}>
        <div>
          <div class="w-12 h-12 mb-4 text-[var(--accent)]">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2">{t('services.consultation')}</h3>
          <p class="text-[var(--text-secondary)] text-sm leading-relaxed">{t('services.consultationDesc')}</p>
        </div>
      </ScrollReveal>
    </div>

    <div class="mt-12 text-center">
      <a href={getLocalizedPath(lang, '/services')} class="btn-secondary">
        {t('common.learnMore')}
      </a>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="py-24 lg:py-32 bg-[var(--accent)] relative grain-overlay">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <ScrollReveal client:visible>
        <h2 class="font-serif font-semibold text-[clamp(2rem,4vw,3rem)] text-white mb-6">
          {t('contact.heading')}
        </h2>
        <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center gap-2 px-8 py-4 bg-white text-[var(--accent)] font-sans font-medium text-sm uppercase tracking-wide cursor-pointer transition-all duration-200 hover:bg-cream hover:-translate-y-0.5">
          {t('common.getInTouch')}
        </a>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
