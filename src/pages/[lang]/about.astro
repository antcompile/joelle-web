---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollReveal from '../../islands/ScrollReveal.tsx';
import { type Lang, languages } from '../../i18n/languages';
import { useTranslation, getLocalizedPath } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
---

<BaseLayout title={t('nav.about')} lang={lang}>
  <div class="pt-32 pb-24 lg:pb-32">
    <!-- Portrait + Philosophy -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-32">
      <ScrollReveal client:visible>
        <div class="aspect-[3/4] overflow-hidden">
          <img
            src="/images/about/portrait.jpg"
            alt="Joelle Trad"
            class="w-full h-full object-cover"
          />
        </div>
      </ScrollReveal>

      <ScrollReveal client:visible delay={0.2}>
        <div>
          <p class="text-xs font-sans font-medium uppercase tracking-[0.2em] text-[var(--accent)] mb-8">
            {t('about.title')}
          </p>
          <blockquote class="font-serif text-2xl lg:text-3xl leading-relaxed text-[var(--text-primary)] mb-10">
            &laquo; Transformer moins en beaucoup plus. &raquo;
          </blockquote>
          <div class="space-y-6 text-[var(--text-secondary)] leading-relaxed max-w-prose">
            <p>
              {lang === 'fr'
                ? "Je suis Joelle Trad, architecte d'interieur basee a Paris."
                : lang === 'ar'
                ? "أنا جويل تراد، مهندسة معمارية داخلية مقيمة في باريس."
                : "I'm Joelle Trad, interior architect based in Paris."}
            </p>
            <p>
              {lang === 'fr'
                ? "Mon travail explore une certaine idee de l'art de vivre, ou architecture, design et fonction s'accordent avec precision et evidence. Je concois des interieurs et imagine des pieces de mobilier multifonctionnelles, pensees pour accompagner les usages contemporains, notamment dans des espaces compacts."
                : lang === 'ar'
                ? "عملي يستكشف فكرة معينة عن فن العيش، حيث تتناغم العمارة والتصميم والوظيفة بدقة وبديهية."
                : "My work explores a certain idea of the art of living, where architecture, design and function come together with precision and clarity. I design interiors and create multifunctional furniture pieces, thoughtfully crafted to support contemporary lifestyles, particularly in compact spaces."}
            </p>
            <p>
              {lang === 'fr'
                ? "Chaque projet est une recherche d'equilibre, une ecriture juste ou chaque element trouve naturellement sa place. Je privilegie la clarte des lignes, la discretion des solutions et une elegance qui se devoile dans l'usage."
                : lang === 'ar'
                ? "كل مشروع هو بحث عن التوازن، كتابة دقيقة حيث يجد كل عنصر مكانه بشكل طبيعي."
                : "Each project is a search for balance, a precise composition where every element finds its natural place. I prioritize clarity of lines, discretion of solutions, and an elegance that reveals itself in use."}
            </p>
            <p>
              {lang === 'fr'
                ? "Dans les espaces reduits, je vois avant tout une opportunite de repenser la maniere d'habiter. A travers des interventions sur mesure et des objets penses pour transformer l'espace, je cherche a reveler une nouvelle fluidite, ou confort, fonctionnalite et esthetique coexistent avec simplicite et exigence."
                : lang === 'ar'
                ? "في المساحات الصغيرة، أرى قبل كل شيء فرصة لإعادة التفكير في طريقة السكن."
                : "In small spaces, I see above all an opportunity to rethink the way we live. Through bespoke interventions and objects designed to transform space, I seek to reveal a new fluidity, where comfort, functionality and aesthetics coexist with simplicity and rigor."}
            </p>
          </div>
        </div>
      </ScrollReveal>
    </section>

    <!-- CTA -->
    <section class="max-w-[1440px] mx-auto px-6 lg:px-12 text-center">
      <ScrollReveal client:visible>
        <a href={getLocalizedPath(lang, '/contact')} class="btn-primary">
          {t('common.getInTouch')}
        </a>
      </ScrollReveal>
    </section>
  </div>
</BaseLayout>
