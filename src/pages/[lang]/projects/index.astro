---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollReveal from '../../../islands/ScrollReveal.tsx';
import { type Lang, languages } from '../../../i18n/languages';
import { useTranslation, getLocalizedPath } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);

const categories = ['all', 'residential', 'commercial'] as const;
const categoryLabels: Record<string, string> = {
  all: t('projects.filterAll'),
  residential: t('projects.filterResidential'),
  commercial: t('projects.filterCommercial'),
};

const residentialImages = [
  '/joelle-web/images/projects/residential/bedroom-pink.jpg',
  '/joelle-web/images/projects/residential/bedroom-elegant.jpg',
  '/joelle-web/images/projects/residential/room-newyork.jpg',
  '/joelle-web/images/projects/residential/living-modern.jpg',
  '/joelle-web/images/projects/residential/living-library.jpg',
  '/joelle-web/images/projects/residential/bedroom-tropical.jpg',
  '/joelle-web/images/projects/residential/salon-white.jpg',
  '/joelle-web/images/projects/residential/outdoor-pool.jpg',
  '/joelle-web/images/projects/residential/outdoor-terrace.jpg',
];

const commercialImages = [
  '/joelle-web/images/projects/commercial/boutique-1.jpg',
  '/joelle-web/images/projects/commercial/boutique-2.jpg',
  '/joelle-web/images/projects/commercial/boutique-3.jpg',
  '/joelle-web/images/projects/commercial/office-1.jpg',
  '/joelle-web/images/projects/commercial/office-2.jpg',
  '/joelle-web/images/projects/commercial/meeting.jpg',
  '/joelle-web/images/projects/commercial/bar-1.jpg',
  '/joelle-web/images/projects/commercial/bar-2.jpg',
  '/joelle-web/images/projects/commercial/bar-3.jpg',
];
---

<BaseLayout title={t('nav.projects')} description={t('projects.title')} lang={lang}>
  <div class="pt-32 pb-24 lg:pb-32 max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16">
      <h1 class="font-serif text-[clamp(2.5rem,5vw,3.5rem)] tracking-[0.05em] mb-8">
        {t('projects.title')}
      </h1>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap gap-6 mb-16" role="tablist">
      {categories.map((cat) => (
        <button
          data-filter={cat}
          class="text-sm font-sans font-medium uppercase tracking-[0.1em] px-1 py-2 border-b-2 border-transparent transition-colors duration-200 cursor-pointer hover:text-[var(--accent)] data-[active]:text-[var(--accent)] data-[active]:border-[var(--accent)]"
          role="tab"
          aria-selected={cat === 'all' ? 'true' : 'false'}
        >
          {categoryLabels[cat]}
        </button>
      ))}
    </div>

    <!-- Residential Section -->
    <div data-section="residential" class="mb-24">
      <ScrollReveal client:visible>
        <div class="mb-10">
          <h2 class="font-serif text-2xl tracking-wide mb-4">{t('projects.filterResidential')}</h2>
          <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
            {lang === 'fr'
              ? "Chaque projet est une reponse unique a une maniere d'habiter. Entre volumes, matieres et lumiere, ces espaces racontent une histoire — celle de leurs occupants."
              : "Each project is a unique response to a way of living. Between volumes, materials and light, these spaces tell a story — that of their occupants."}
          </p>
        </div>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
        {residentialImages.map((img, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <div class="group overflow-hidden cursor-pointer" data-category="residential">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={img}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>

    <!-- Commercial Section -->
    <div data-section="commercial">
      <ScrollReveal client:visible>
        <div class="mb-10">
          <h2 class="font-serif text-2xl tracking-wide mb-4">{t('projects.filterCommercial')}</h2>
          <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
            {lang === 'fr'
              ? "Des projets aux identites multiples, penses pour repondre a des usages varies et des univers distincts. Chaque espace est concu comme une experience, ou l'architecture traduit une vision de marque, un rythme, une fonction."
              : "Projects with multiple identities, designed to meet varied uses and distinct worlds. Each space is conceived as an experience, where architecture translates a brand vision, a rhythm, a function."}
          </p>
        </div>
      </ScrollReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
        {commercialImages.map((img, i) => (
          <ScrollReveal client:visible delay={i * 0.08}>
            <div class="group overflow-hidden cursor-pointer" data-category="commercial">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={img}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </div>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('[data-filter]');
  const residentialSection = document.querySelector('[data-section="residential"]');
  const commercialSection = document.querySelector('[data-section="commercial"]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach((b) => {
        b.removeAttribute('data-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.setAttribute('data-active', '');
      btn.setAttribute('aria-selected', 'true');

      if (filter === 'all') {
        (residentialSection as HTMLElement).style.display = '';
        (commercialSection as HTMLElement).style.display = '';
      } else if (filter === 'residential') {
        (residentialSection as HTMLElement).style.display = '';
        (commercialSection as HTMLElement).style.display = 'none';
      } else if (filter === 'commercial') {
        (residentialSection as HTMLElement).style.display = 'none';
        (commercialSection as HTMLElement).style.display = '';
      }
    });
  });

  buttons[0]?.setAttribute('data-active', '');
</script>
