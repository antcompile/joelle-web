---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollReveal from '../../../islands/ScrollReveal.tsx';
import ProjectGallery from '../../../islands/ProjectGallery.tsx';
import PanoramaViewer from '../../../islands/PanoramaViewer.tsx';
import { type Lang, languages } from '../../../i18n/languages';
import { useTranslation } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);

const categories = ['all', 'residential', 'commercial', '360'] as const;
const categoryLabels: Record<string, string> = {
  all: t('projects.filterAll'),
  residential: t('projects.filterResidential'),
  commercial: t('projects.filterCommercial'),
  '360': t('projects.filter360'),
};

const residentialImages = Array.from({ length: 10 }, (_, i) =>
  `/images/projects/residential/${String(i + 1).padStart(2, '0')}.jpg`
);

const commercialImages = Array.from({ length: 9 }, (_, i) =>
  `/images/projects/commercial/${String(i + 1).padStart(2, '0')}.jpg`
);
---

<BaseLayout title={t('nav.projects')} description={t('projects.title')} lang={lang}>
  <div class="pt-32 pb-24 lg:pb-32 max-w-[1440px] mx-auto px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16">
      <h1 class="font-serif text-[clamp(2.5rem,5vw,3.5rem)] tracking-[0.05em] mb-8">
        {t('projects.title')}
      </h1>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap gap-6 mb-16" role="tablist">
      {categories.map((cat) => (
        <button
          data-filter={cat}
          class="text-sm font-sans font-medium uppercase tracking-[0.1em] px-1 py-2 border-b-2 border-transparent transition-colors duration-200 cursor-pointer hover:text-[var(--accent)] data-[active]:text-[var(--accent)] data-[active]:border-[var(--accent)]"
          role="tab"
          aria-selected={cat === 'all' ? 'true' : 'false'}
        >
          {categoryLabels[cat]}
        </button>
      ))}
    </div>

    <!-- Residential Section -->
    <div data-section="residential" class="mb-24">
      <ScrollReveal client:visible>
        <div class="mb-10">
          <h2 class="font-serif text-2xl tracking-wide mb-4">{t('projects.filterResidential')}</h2>
          <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
            {lang === 'fr'
              ? "Chaque projet est une reponse unique a une maniere d'habiter. Entre volumes, matieres et lumiere, ces espaces racontent une histoire - celle de leurs occupants. Pensees dans le detail et concues avec precision, ces realisations traduisent un equilibre entre esthetique, usage et emotion."
              : "Each project is a unique response to a way of living. Between volumes, materials and light, these spaces tell a story - that of their occupants. Designed with attention to detail and precision, these creations translate a balance between aesthetics, use and emotion."}
          </p>
        </div>
      </ScrollReveal>

      <ProjectGallery client:visible images={residentialImages} />
    </div>

    <!-- Commercial Section -->
    <div data-section="commercial">
      <ScrollReveal client:visible>
        <div class="mb-10">
          <h2 class="font-serif text-2xl tracking-wide mb-4">{t('projects.filterCommercial')}</h2>
          <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
            {lang === 'fr'
              ? "Des projets aux identites multiples, penses pour repondre a des usages varies et des univers distincts. Chaque espace est concu comme une experience, ou l'architecture traduit une vision de marque, un rythme, une fonction."
              : "Projects with multiple identities, designed to meet varied uses and distinct worlds. Each space is conceived as an experience, where architecture translates a brand vision, a rhythm, a function."}
          </p>
        </div>
      </ScrollReveal>

      <ProjectGallery client:visible images={commercialImages} />
    </div>

    <!-- 360 Section -->
    <div data-section="360" class="mb-24">
      <ScrollReveal client:visible>
        <div class="mb-10">
          <h2 class="font-serif text-2xl tracking-wide mb-4">{t('projects.360title')}</h2>
          <p class="text-[var(--text-secondary)] max-w-2xl leading-relaxed">
            {t('projects.360desc')}
          </p>
        </div>
      </ScrollReveal>

      <PanoramaViewer
        client:visible
        imageSrc="/images/projects/360/panorama-01.jpg"
        hint={t('projects.360hint')}
      />
    </div>
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('[data-filter]');
  const sections = {
    residential: document.querySelector('[data-section="residential"]') as HTMLElement,
    commercial: document.querySelector('[data-section="commercial"]') as HTMLElement,
    '360': document.querySelector('[data-section="360"]') as HTMLElement,
  };

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach((b) => {
        b.removeAttribute('data-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.setAttribute('data-active', '');
      btn.setAttribute('aria-selected', 'true');

      if (filter === 'all') {
        Object.values(sections).forEach((s) => { if (s) s.style.display = ''; });
      } else {
        Object.entries(sections).forEach(([key, s]) => {
          if (s) s.style.display = key === filter ? '' : 'none';
        });
      }
    });
  });

  buttons[0]?.setAttribute('data-active', '');
</script>
