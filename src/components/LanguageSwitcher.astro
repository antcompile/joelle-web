---
import { type Lang, languages } from '../i18n/languages';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getSwitchedPath(targetLang: Lang): string {
  const pathWithoutBase = currentPath.replace(new RegExp(`^${base}`), '');
  const newPath = pathWithoutBase.replace(/^\/(fr|en|ar)/, `/${targetLang}`);
  return `${base}${newPath}`;
}

const langLabels: Record<Lang, string> = {
  fr: 'FR',
  en: 'EN',
  ar: 'عربي',
};
---

<nav class="flex items-center gap-1 text-sm [color:inherit]" aria-label="Select language">
  {(Object.keys(languages) as Lang[]).map((l, i) => (
    <>
      {i > 0 && <span class="opacity-50">|</span>}
      <a
        href={getSwitchedPath(l)}
        class:list={[
          'px-1 transition-colors duration-200 cursor-pointer',
          l === lang ? 'opacity-100 font-medium' : 'opacity-60 hover:opacity-100',
        ]}
        aria-current={l === lang ? 'true' : undefined}
      >
        {langLabels[l]}
      </a>
    </>
  ))}
</nav>
