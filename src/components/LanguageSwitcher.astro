---
import { type Lang, languages } from '../i18n/languages';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;

function getSwitchedPath(targetLang: Lang): string {
  return currentPath.replace(/^\/(fr|en|ar)/, `/${targetLang}`);
}

const langLabels: Record<Lang, string> = {
  fr: 'FR',
  en: 'EN',
  ar: 'عربي',
};
---

<nav class="flex items-center gap-1 text-sm" aria-label="Select language">
  {(Object.keys(languages) as Lang[]).map((l, i) => (
    <>
      {i > 0 && <span class="text-[var(--text-muted)]">|</span>}
      <a
        href={getSwitchedPath(l)}
        class:list={[
          'px-1 transition-colors duration-200 cursor-pointer',
          l === lang ? 'text-[var(--accent)] font-medium' : 'text-[var(--text-secondary)] hover:text-[var(--accent)]',
        ]}
        aria-current={l === lang ? 'true' : undefined}
      >
        {langLabels[l]}
      </a>
    </>
  ))}
</nav>
